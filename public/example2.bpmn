  <bpmn:process id="example2" isExecutable="true">
    <bpmn:startEvent id="startEvent" name="Start">
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="startEvent" targetRef="subProcess" />
    <bpmn:subProcess id="subProcess">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:startEvent id="subProcessStartEvent">
        <bpmn:outgoing>f2</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:sequenceFlow id="f2" sourceRef="subProcessStartEvent" targetRef="doX" />
      <bpmn:serviceTask id="doX" name="Do X">
        <bpmn:incoming>f2</bpmn:incoming>
        <bpmn:outgoing>f3</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:sequenceFlow id="f3" sourceRef="doX" targetRef="escalationFork" />
      <bpmn:exclusiveGateway id="escalationFork" name="Escalate?" default="f4">
        <bpmn:incoming>f3</bpmn:incoming>
        <bpmn:outgoing>f4</bpmn:outgoing>
        <bpmn:outgoing>f5</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:sequenceFlow id="f4" name="No" sourceRef="escalationFork" targetRef="subProcessEndEvent" />
      <bpmn:endEvent id="subProcessEndEvent">
        <bpmn:incoming>f4</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="f5" name="Yes" sourceRef="escalationFork" targetRef="escalationEndEvent" />
      <bpmn:endEvent id="escalationEndEvent">
        <bpmn:incoming>f5</bpmn:incoming>
        <bpmn:escalationEventDefinition id="escalationEndEventDefinition" escalationRef="exampleEscalation" />
      </bpmn:endEvent>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:subProcess>
    <bpmn:endEvent id="endEvent" name="End">
      <bpmn:incoming>f6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f6" sourceRef="subProcess" targetRef="endEvent" />
    <bpmn:boundaryEvent id="escalationBoundaryEvent" attachedToRef="subProcess">
      <bpmn:outgoing>f7</bpmn:outgoing>
      <bpmn:escalationEventDefinition id="escalationBoundaryEventDefinition" escalationRef="exampleEscalation" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="messageBoundaryEvent" attachedToRef="subProcess">
      <bpmn:outgoing>f8</bpmn:outgoing>
      <bpmn:messageEventDefinition id="messageBoundaryEventDefinition" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="signalBoundaryEvent" attachedToRef="subProcess">
      <bpmn:outgoing>f9</bpmn:outgoing>
      <bpmn:signalEventDefinition id="signalBoundaryEventDefinition" signalRef="exampleSignal" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="timerBoundaryEvent" attachedToRef="subProcess">
      <bpmn:outgoing>f10</bpmn:outgoing>
      <bpmn:timerEventDefinition id="timerBoundaryEventDefinition" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="f8" sourceRef="messageBoundaryEvent" targetRef="alternativeJoin" />
    <bpmn:sequenceFlow id="f9" sourceRef="signalBoundaryEvent" targetRef="alternativeJoin" />
    <bpmn:sequenceFlow id="f10" sourceRef="timerBoundaryEvent" targetRef="alternativeJoin" />
    <bpmn:sequenceFlow id="f7" sourceRef="escalationBoundaryEvent" targetRef="alternativeJoin" />
    <bpmn:exclusiveGateway id="alternativeJoin">
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="f11" sourceRef="alternativeJoin" targetRef="doY" />
    <bpmn:serviceTask id="doY" name="Do Y">
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="f12" sourceRef="doY" targetRef="alternativeEndEvent" />
    <bpmn:endEvent id="alternativeEndEvent" name="Alternative end">
      <bpmn:incoming>f12</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
