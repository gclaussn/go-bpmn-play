    <bpmn:sequenceFlow id="f1" sourceRef="startEvent" targetRef="parallelFork" />
    <bpmn:parallelGateway id="parallelFork">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
      <bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="f2" sourceRef="parallelFork" targetRef="doX" />
    <bpmn:sequenceFlow id="f3" sourceRef="parallelFork" targetRef="doY" />
    <bpmn:serviceTask id="doX" name="Do X">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="doY" name="Do Y">
