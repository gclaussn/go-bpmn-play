      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="f4" sourceRef="doX" targetRef="parallelJoin" />
    <bpmn:sequenceFlow id="f5" sourceRef="doY" targetRef="parallelJoin" />
    <bpmn:parallelGateway id="parallelJoin">
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="f6" sourceRef="parallelJoin" targetRef="endEvent" />
    <bpmn:endEvent id="endEvent" name="End">
      <bpmn:incoming>f6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:boundaryEvent id="errorBoundaryEvent" attachedToRef="doX">
      <bpmn:outgoing>f7</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errorBoundaryEventDefinition" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="f7" sourceRef="errorBoundaryEvent" targetRef="doZ" />
    <bpmn:serviceTask id="doZ" name="Do Z">
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="f8" sourceRef="doZ" targetRef="errorEnd" />
    <bpmn:endEvent id="errorEnd" name="Error end">
      <bpmn:incoming>f8</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
